{
  "name": "engram-skill-pack",
  "version": "0.2.0",
  "description": "engramx's AST code-graph + bi-temporal mistakes as auto-discoverable Claude Code Skills",
  "author": "Nicholas Ashkar (@NickCirv)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/NickCirv/engram-skill-pack",
  "requires": [
    { "type": "cli", "name": "engramx", "version": ">=4.0.0" }
  ],
  "skills": [
    {
      "id": "engram-mistakes",
      "status": "active",
      "path": "skills/engram-mistakes/SKILL.md",
      "summary": "Surface bi-temporal mistakes from this repo before your agent repeats them",
      "triggers": [
        "have i made this before",
        "any mistakes",
        "what did i learn",
        "remind me of past attempts",
        "did i try this already"
      ],
      "pre_tool_use": {
        "tools": ["Edit", "Write", "Bash"],
        "file_path_matches": "\\.(ts|tsx|js|jsx|py|rb|go|rs|java|c|cpp|cs|php)$",
        "file_path_excludes": "node_modules|dist|build|\\.next|\\.nuxt|coverage"
      }
    },
    {
      "id": "engram-query",
      "status": "active",
      "path": "skills/engram-query/SKILL.md",
      "summary": "Natural-language structural queries over your repo's code graph — replaces ad-hoc Grep with AST-aware lookups at a fraction of the token cost",
      "triggers": [
        "where is",
        "what calls",
        "explain the architecture",
        "show me dependencies",
        "what depends on",
        "find all"
      ]
    },
    {
      "id": "engram-gods",
      "status": "active",
      "path": "skills/engram-gods/SKILL.md",
      "summary": "Surface the most-important entities in a repo — bootstrap repo understanding in seconds, not turns",
      "triggers": [
        "where do i start",
        "where should i start",
        "what's important",
        "what are the main",
        "executive summary",
        "onboarding",
        "what anchors this"
      ]
    },
    {
      "id": "engram-gen",
      "status": "placeholder",
      "summary": "Generate task-grounded context prompts — lands in v0.3.0"
    },
    {
      "id": "engram-learn",
      "status": "placeholder",
      "summary": "Capture bi-temporal mistakes manually with interactive 4-field prompt — lands in v0.3.0"
    }
  ]
}
